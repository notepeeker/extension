{
  "manifest_version": 3,
  "name": "NotePeeker",
  "version": "0.2.0",
  "description": "View Markdown files in a clean browser document viewer.",
  "icons": {
    "16": "components/notepeeker.png",
    "32": "components/notepeeker.png",
    "48": "components/notepeeker.png",
    "128": "components/notepeeker.png"
  },
  "action": {
    "default_title": "NotePeeker",
    "default_icon": {
      "16": "components/notepeeker.png",
      "32": "components/notepeeker.png",
      "48": "components/notepeeker.png",
      "128": "components/notepeeker.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "webNavigation"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "file:///*"
  ]
}
